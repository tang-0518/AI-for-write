# =============================================================
# PlotPilot 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# =============================================================

# ── AI 模型（至少配置一个） ────────────────────────────────────

# Anthropic Claude（推荐）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=           # 可选，自建网关时填

# 字节跳动 Ark / 豆包（备选）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TIMEOUT=120
ARK_REASONING_EFFORT=medium
# ARK_NO_PROXY=1                # 代理 TLS 问题时直连

# ── 向量数据库 Qdrant ─────────────────────────────────────────
# Docker 部署：保持 qdrant（service name）
# 本地开发：改为 localhost
QDRANT_HOST=qdrant

# ── 嵌入模型 ──────────────────────────────────────────────────
# local = 使用镜像内置 BAAI/bge-small-zh-v1.5（推荐，无需 API）
# openai = 使用 OpenAI text-embedding-ada-002
EMBEDDING_SERVICE=local

# ── 服务配置 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/aitext.log

# 生产环境：允许的跨域来源（逗号分隔）
# CORS_ORIGINS=http://localhost:3000

# 禁用自动守护进程（调试时有用）
# DISABLE_AUTO_DAEMON=true

# 可选默认生成参数
# AITEXT_DEFAULT_CHAPTERS=5
# AITEXT_DEFAULT_WORDS_PER_CHAPTER=2500
# AITEXT_SUMMARY_MAX_CHAPTERS=5
